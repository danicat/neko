{
  "name": "javascript",
  "languageId": "javascript",
  "extensions": [".js", ".mjs", ".cjs", ".jsx"],
  "projectMarkers": ["package.json", "package-lock.json"],
  "skipDirs": ["node_modules", "dist", "build", ".next", ".cache"],
  "tier": 2,
  "lsp": {
    "command": "typescript-language-server",
    "args": ["--stdio"]
  },
  "commands": {
    "validate": {
      "command": "node",
      "args": ["-c", "{{filename}}"]
    },
    "format": {
      "command": "npx",
      "args": ["prettier", "--write", "{{filename}}"]
    },
    "addDependency": {
      "command": "npm",
      "args": ["install", "{{packages...}}", "--prefix", "{{dir}}"]
    },
    "init": {
      "command": "npm",
      "args": ["init", "-y", "--prefix", "{{dir}}"]
    },
    "fetchDocs": {
      "command": "npm",
      "args": ["view", "{{package}}", "description"]
    },
    "modernize": {
      "command": "npx",
      "args": ["eslint", "--fix", "."]
    }
  },
  "buildSteps": [
    {"command": "npm", "args": ["run", "build", "--prefix", "{{dir}}"]},
    {"command": "npm", "args": ["test", "--prefix", "{{dir}}"]}
  ]
}
